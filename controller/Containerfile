FROM rust:1.96-slim AS builder
RUN apt-get update && apt-get install -y \
  protobuf-compiler \
  && rm -rf /var/lib/apt/lists/*
WORKDIR /build
COPY . .
RUN cargo build --release -p controller

FROM debian:trixie-slim
RUN useradd -r -s /bin/false -d /data zkrp
COPY --from=builder /build/target/release/controller /usr/local/bin/zkrp-relay
ENTRYPOINT ["/usr/local/bin/zkrp-relay"]
